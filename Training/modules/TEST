	@Override
	public boolean serveResource(ResourceRequest resourceRequest, ResourceResponse resourceResponse) {

		_log.info("Inside Serve Resource Method");

		long groupId = 39129;
		long folderId = 58078172;
		long structureId = 56730470;
		long templateId = 56730493;

		try {

			ServiceContext serviceContext = ServiceContextFactory.getInstance(JournalArticle.class.getName(),
					resourceRequest);

			List<ProcurementNewsTest> list = new LinkedList<ProcurementNewsTest>();
			
			list = ProcurementNewsTestLocalServiceUtil.getAllRecords();

			_log.info("Size---------------->" + list.size());

			for (ProcurementNewsTest procurementNewsTest : list) {

				Map<Locale, String> titleMap = new HashMap<>();

				if(procurementNewsTest.getTenderDescription().length() > 50 ) {
					titleMap.put(Locale.US, procurementNewsTest.getTenderDescription().substring(0, 50));
				}
				
				titleMap.put(Locale.US, procurementNewsTest.getTenderDescription());

				Map<Locale, String> descriptionMap = new HashMap<>();

				descriptionMap.put(Locale.US, procurementNewsTest.getTenderDescription());

				Group group = groupLocalService.getGroup(groupId);

				JournalFolder journalFolder = journalFolderLocalService.getFolder(folderId);

				DDMStructure ddmStructure = ddmStructureLocalService.getDDMStructure(structureId);

				DDMTemplate ddmTemplate = ddmTemplateLocalService.getDDMTemplate(templateId);

				Fields ddmFields = getFields(ddmStructure, procurementNewsTest);

				try {
					

					journalArticleLocalService.addArticle(104, group.getGroupId(), journalFolder.getFolderId(),
							titleMap, descriptionMap, journalConverter.getContent(ddmStructure, ddmFields),
							ddmStructure.getStructureKey(), ddmTemplate.getTemplateKey(), serviceContext);

				} catch (Exception e) {
					_log.info("Exception ID_------------->"+procurementNewsTest.getId_());
					_log.error(e);
					
				}

			}

		} catch (Exception e) {
			
			
			_log.error(e);
		}

		return false;

	}


public Fields getFields(DDMStructure ddmStructure, ProcurementNewsTest data) throws PortalException {

		try {

			return ddmFormValuesToFieldsConverter.convert(ddmStructure, constructDMMFormValues(ddmStructure, data));
		} catch (Exception e) {
			_log.error(e);
			return null;
		}

	}


	public DDMFormValues constructDMMFormValues(DDMStructure structure, ProcurementNewsTest procurementNewsTest)
			throws PortalException {

		DDMFormValues ddmFormValues = new DDMFormValues(structure.getDDMForm());

		List<DDMFormFieldValue> ddmFormFieldValues = new ArrayList<>();

		List<DDMFormField> ddmFormFields = structure.getDDMForm().getDDMFormFields();

		_log.info("structure.getDefaultLanguageId() = " + structure.getDefaultLanguageId());

		for (DDMFormField ddmFormField : ddmFormFields) {

			String val = StringPool.BLANK;
			if ("Location".equalsIgnoreCase(ddmFormField.getName())) {
				val = procurementNewsTest.getLocation();
			} else if ("TenderDescription".equalsIgnoreCase(ddmFormField.getName())) {
				val = procurementNewsTest.getTenderDescription();
			} else if ("EndDate".equalsIgnoreCase(ddmFormField.getName())) {
				val = procurementNewsTest.getEndDate();
			} else if ("StartDate".equalsIgnoreCase(ddmFormField.getName())) {
				val = procurementNewsTest.getStartDate();
			}

			else if ("SupportingLinks".equalsIgnoreCase(ddmFormField.getName())) {
				
				_log.info("HTML------------>" + procurementNewsTest.getSupportingLinks().toString());
				
				//replacing documents with document so that code don't break while finding the file in UAT
				val = procurementNewsTest.getSupportingLinks().toString().replace("documents", "document");
			}
			Locale locale = new Locale("en", "US");
			Value value = new LocalizedValue(locale);
			DDMFormFieldValue ddmFormFieldValue = new DDMFormFieldValue();
			ddmFormFieldValue.setName(ddmFormField.getName());
			value.addString(locale, val);
			ddmFormFieldValue.setValue(value);
			ddmFormFieldValues.add(ddmFormFieldValue);

		}

		ddmFormValues.setDDMFormFieldValues(ddmFormFieldValues);

		return ddmFormValues;
	}
