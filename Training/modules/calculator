	<entity name="InterestRate" local-service="true" remote-service="false">
		<column name="interestRateId" type="long" primary="true" />
		<column name="companyId" type="long" />
		<column name="groupId" type="long" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- NORMAL | SENIOR_CITIZEN | CORPORATE -->
		<column name="customerType" type="String" />
		<column name="productCode" type="String" />

		<!-- inclusive day-range this row applies to, e.g. 91-365 -->
		<column name="tenureMinDays" type="int" />
		<column name="tenureMaxDays" type="int" />

		<column name="interestRatePct" type="double" />
		<!-- compounding periods/year; spec fixes this at 4 (quarterly) -->
		<column name="compoundingFrequency" type="int" />
		<column name="active" type="boolean" />

		<order by="asc">
			<order-column name="tenureMinDays" />
		</order>

		<finder name="C_P_Active" return-type="Collection">
			<finder-column name="customerType" />
			<finder-column name="productCode" />
			<finder-column name="active" />
		</finder>
	</entity>

	<entity name="DepositProduct" local-service="true" remote-service="false">
		<column name="productId" type="long" primary="true" />
		<column name="companyId" type="long" />
		<column name="groupId" type="long" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<column name="productCode" type="String" />
		<column name="productName" type="String" />
		<column name="active" type="boolean" />

		<order by="asc">
			<order-column name="productName" />
		</order>

		<finder name="Active" return-type="Collection">
			<finder-column name="active" />
		</finder>
	</entity>
</service-builder>

--- Custom range finder (added by hand to the generated *FinderImpl) --------
-- Service Builder can't express "tenureMinDays <= :days <= tenureMaxDays"
-- declaratively, so this method is added to InterestRateFinderImpl once and
-- survives regeneration because Finder classes aren't overwritten.

package com.lr.trainong.depositrate.service.persistence.impl;

public class InterestRateFinderImpl
	extends InterestRateFinderBaseImpl implements InterestRateFinder {

	public InterestRate findByCustomerType_Product_Tenure(
			String customerType, String productCode, int tenureDays)
		throws SystemException {

		Session session = null;

		try {
			session = openSession();

			String sql =
				"SELECT * FROM DEPRATE_InterestRate WHERE customerType = ? " +
				"AND productCode = ? AND active = ? " +
				"AND tenureMinDays <= ? AND tenureMaxDays >= ?";

			SQLQuery q = session.createSQLQuery(sql);

			q.addEntity("DEPRATE_InterestRate", InterestRateImpl.class);

			QueryPos qPos = QueryPos.getInstance(q);

			qPos.add(customerType);
			qPos.add(productCode);
			qPos.add(true);
			qPos.add(tenureDays);
			qPos.add(tenureDays);

			List<InterestRate> results = q.list();

			return results.isEmpty() ? null : results.get(0);
		}
		catch (Exception e) {
			throw new SystemException(e);
		}
		finally {
			closeSession(session);
		}
	}
}

