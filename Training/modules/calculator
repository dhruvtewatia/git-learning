// Liferay Fragment JS runs with `fragmentElement` and `configuration` already
// in scope. Every rate this file needs was embedded server-side by the FTL
// block in index.html, so there is no fetch()/Promise/retry code here at all.

(function initDepositCalculator(root) {
	if (!root) {
		return;
	}

	var rates = [];
	var ratesDataEl = root.querySelector('[data-output="ratesData"]');

	try {
		rates = ratesDataEl ? JSON.parse(ratesDataEl.textContent) : [];
	}
	catch (err) {
		/* eslint-disable-next-line no-console */
		console.error('Could not parse embedded rate data', err);
	}

	var interestTypeSelect = root.querySelector('[data-field="interestType"]');
	var payoutRadios = root.querySelectorAll('input[name="payoutFrequency"]');
	var errorEl = root.querySelector('[data-field="error"]');
	var calculateBtn = root.querySelector('[data-action="calculate"]');
	var viewRatesBtn = root.querySelector('[data-action="view-rates"]');
	var ratesTable = root.querySelector('[data-output="ratesTable"]');

	function getSelectedCategory() {
		var checked = root.querySelector('input[name="customerType"]:checked');

		return checked ? checked.value : null;
	}

	function getRatesForCategory(category) {
		return rates.filter(function(rate) {
			return rate.category === category;
		});
	}

	function findSelectedRate() {
		var category = getSelectedCategory();
		var interestType = interestTypeSelect.value;

		return rates.filter(function(rate) {
			return rate.category === category && rate.interestType === interestType;
		})[0] || null;
	}

	function setOutput(field, value) {
		var el = root.querySelector('[data-output="' + field + '"]');

		if (el) {
			el.textContent = value;
		}
	}

	function updateSelectedRateDisplay() {
		var rate = findSelectedRate();

		setOutput('interestRate', rate ? rate.interestRate.toFixed(2) + '%' : '-');
	}

	function populateInterestTypes() {
		var previousValue = interestTypeSelect.value;
		var options = getRatesForCategory(getSelectedCategory());

		interestTypeSelect.innerHTML = '';

		options.forEach(function(rate) {
			var optionEl = document.createElement('option');

			optionEl.value = rate.interestType;
			optionEl.textContent = rate.interestType + ' (' + rate.interestRate.toFixed(2) + '%)';

			interestTypeSelect.appendChild(optionEl);
		});

		if (options.some(function(rate) { return rate.interestType === previousValue; })) {
			interestTypeSelect.value = previousValue;
		}

		updateSelectedRateDisplay();
	}

	function showError(message) {
		if (!errorEl) {
			return;
		}
		errorEl.textContent = message;
		errorEl.hidden = !message;
	}

	function formatCurrency(amount) {
		return '₹' + amount.toFixed(2);
	}

	function getTenureDays() {
		var years = Number(root.querySelector('[data-field="tenureYears"]').value) || 0;
		var months = Number(root.querySelector('[data-field="tenureMonths"]').value) || 0;
		var days = Number(root.querySelector('[data-field="tenureDays"]').value) || 0;

		return Math.round(years * 365 + months * 30 + days);
	}

	function getTenureYearsDecimal() {
		var years = Number(root.querySelector('[data-field="tenureYears"]').value) || 0;
		var months = Number(root.querySelector('[data-field="tenureMonths"]').value) || 0;
		var days = Number(root.querySelector('[data-field="tenureDays"]').value) || 0;

		// Annexure 4 tenure conversion: years stay as-is, months/12, days/365.
		return years + (months / 12) + (days / 365);
	}

	// Field-table rule: which payout options are legal for a given tenure.
	function getAvailablePayoutFrequencies(totalDays) {
		if (totalDays < 30) {
			return ['MATURITY'];
		}
		if (totalDays < 90) {
			return ['MONTHLY', 'MATURITY'];
		}
		if (totalDays < 365) {
			return ['MONTHLY', 'QUARTERLY', 'MATURITY'];
		}
		return ['MONTHLY', 'QUARTERLY', 'ANNUALLY', 'MATURITY'];
	}

	function updatePayoutOptions() {
		var available = getAvailablePayoutFrequencies(getTenureDays());

		payoutRadios.forEach(function(radio) {
			var isAvailable = available.indexOf(radio.value) !== -1;

			radio.disabled = !isAvailable;

			if (radio.checked && !isAvailable) {
				radio.checked = false;
			}
		});

		var anyChecked = Array.prototype.some.call(payoutRadios, function(r) {
			return r.checked;
		});

		if (!anyChecked) {
			var maturityRadio = root.querySelector('input[value="MATURITY"]');

			if (maturityRadio) {
				maturityRadio.checked = true;
			}
		}
	}

	// Annexure 4: A = P x (1 + r/n)^(n x t), n fixed at 4 (quarterly).
	function calculateMaturity(principal, ratePct, tenureYears) {
		var n = 4;
		var r = ratePct / 100;

		return principal * Math.pow(1 + r / n, n * tenureYears);
	}

	// Per-year payout for Annually: quarterly compounding within the year,
	// principal resets each year since the payout removes that year's
	// interest rather than reinvesting it.
	function calculateAnnualPayoutPerYear(principal, ratePct) {
		var n = 4;
		var r = ratePct / 100;

		return principal * (Math.pow(1 + r / n, n) - 1);
	}

	function calculateAnnualRemainderAtMaturity(principal, ratePct, tenureYears) {
		var n = 4;
		var r = ratePct / 100;
		var remainderYears = tenureYears - Math.floor(tenureYears);

		if (remainderYears <= 0) {
			return 0;
		}

		return principal * (Math.pow(1 + r / n, n * remainderYears) - 1);
	}

	function calculatePayoutAmount(payoutFrequency, principal, ratePct, tenureYears, totalInterest) {
		var totalMonths = tenureYears * 12;

		switch (payoutFrequency) {
			case 'QUARTERLY':
				// flat non-cumulative quarterly interest, per Annexure 4 example
				// (100000 @ 8% => 100000*0.08/4 = 2000/quarter)
				return principal * (ratePct / 100) / 4;

			case 'MONTHLY':
				// total compounded interest spread evenly across the tenure,
				// per Annexure 4 example (8243 / 12 months ~= 687/month)
				return totalMonths > 0 ? totalInterest / totalMonths : 0;

			case 'ANNUALLY':
				return calculateAnnualPayoutPerYear(principal, ratePct);

			case 'MATURITY':
			default:
				return totalInterest;
		}
	}

	function validate(principal, tenureDays, rate) {
		if (!principal || principal < 10000 || principal > 999999) {
			return 'Amount must be between ₹10,000 and ₹9,99,999.';
		}
		if (tenureDays <= 0) {
			return 'Please enter a valid tenure.';
		}
		if (!rate) {
			return 'No active rate found for this selection.';
		}
		return null;
	}

	function handleCalculate() {
		showError('');

		var principal = Number(root.querySelector('[data-field="amount"]').value);
		var tenureDays = getTenureDays();
		var tenureYears = getTenureYearsDecimal();
		var payoutFrequency = root.querySelector('input[name="payoutFrequency"]:checked').value;
		var rate = findSelectedRate();

		var validationError = validate(principal, tenureDays, rate);

		if (validationError) {
			showError(validationError);
			return;
		}

		var maturityAmount = calculateMaturity(principal, rate.interestRate, tenureYears);
		var totalInterest = maturityAmount - principal;
		var payoutAmount = calculatePayoutAmount(
			payoutFrequency, principal, rate.interestRate, tenureYears, totalInterest);

		setOutput('maturityAmount', formatCurrency(maturityAmount));
		setOutput('interestAmount', formatCurrency(totalInterest));

		if (payoutFrequency === 'ANNUALLY') {
			var remainder = calculateAnnualRemainderAtMaturity(principal, rate.interestRate, tenureYears);

			setOutput('payoutAmount', formatCurrency(payoutAmount) + '/year' +
				(remainder > 0 ? ' (+ ' + formatCurrency(remainder) + ' at maturity for the part-year)' : ''));
		}
		else {
			setOutput('payoutAmount', formatCurrency(payoutAmount));
		}
	}

	// textContent, not innerHTML — defense in depth even though this data
	// came from our own SSR block, in case the entity ever grows a
	// free-text field editable outside a strict enum.
	function renderRatesTable() {
		var tbody = root.querySelector('[data-output="ratesTableBody"]');

		if (!tbody) {
			return;
		}

		tbody.innerHTML = '';

		rates.forEach(function(rate) {
			var tr = document.createElement('tr');

			[
				rate.category,
				rate.interestType,
				rate.interestRate.toFixed(2) + '%',
				rate.status
			].forEach(function(value) {
				var td = document.createElement('td');

				td.textContent = value;
				tr.appendChild(td);
			});

			tbody.appendChild(tr);
		});
	}

	// -- wiring --
	renderRatesTable();
	populateInterestTypes();
	updatePayoutOptions();

	root.querySelectorAll('input[name="customerType"]').forEach(function(radio) {
		radio.addEventListener('change', populateInterestTypes);
	});

	interestTypeSelect.addEventListener('change', updateSelectedRateDisplay);

	['tenureYears', 'tenureMonths', 'tenureDays'].forEach(function(field) {
		root.querySelector('[data-field="' + field + '"]').addEventListener('input', updatePayoutOptions);
	});

	if (viewRatesBtn && ratesTable) {
		viewRatesBtn.addEventListener('click', function() {
			ratesTable.hidden = !ratesTable.hidden;
			viewRatesBtn.textContent = ratesTable.hidden ?
				'View current interest rates' : 'Hide current interest rates';
		});
	}

	calculateBtn.addEventListener('click', handleCalculate);
})(fragmentElement.querySelector('.deposit-calculator'));
