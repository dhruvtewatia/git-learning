--- index.js ------------------------------------------------------------------
// Liferay Fragment JS runs with `fragmentElement` and `configuration` already
// in scope — no wrapping module/import needed.

(function initDepositCalculator(root, config) {
	if (!root) {
		return;
	}

	var restBase = (config && config.restApplicationPath) ||
		'/o/deposit-rate/v1.0';

	var productSelect = root.querySelector('[data-field="productCode"]');
	var payoutRadios = root.querySelectorAll('input[name="payoutFrequency"]');
	var errorEl = root.querySelector('[data-field="error"]');
	var calculateBtn = root.querySelector('[data-action="calculate"]');

	var currentRate = null; // last rate fetched from the REST resource

	function fetchProducts() {
		return fetch(restBase + '/products', {
			headers: {Accept: 'application/json'},
			credentials: 'same-origin'
		})
			.then(function(res) {
				if (!res.ok) {
					throw new Error('Product list fetch failed: ' + res.status);
				}
				return res.json();
			})
			.then(function(page) {
				var products = (page && page.items) || [];

				products.forEach(function(product) {
					var optionEl = document.createElement('option');

					optionEl.value = product.productCode;
					optionEl.textContent = product.productName;

					productSelect.appendChild(optionEl);
				});

				// trigger the first rate lookup now that a product is selected
				fetchInterestRate();
			})
			.catch(function(err) {
				showError('Could not load the product list. Please refresh.');
				/* eslint-disable-next-line no-console */
				console.error(err);
			});
	}

	function getTenureDays() {
		var years = Number(root.querySelector('[data-field="tenureYears"]').value) || 0;
		var months = Number(root.querySelector('[data-field="tenureMonths"]').value) || 0;
		var days = Number(root.querySelector('[data-field="tenureDays"]').value) || 0;

		return Math.round(years * 365 + months * 30 + days);
	}

	function getTenureYearsDecimal() {
		var years = Number(root.querySelector('[data-field="tenureYears"]').value) || 0;
		var months = Number(root.querySelector('[data-field="tenureMonths"]').value) || 0;
		var days = Number(root.querySelector('[data-field="tenureDays"]').value) || 0;

		// Annexure 4 tenure conversion: years stay as-is, months/12, days/365.
		return years + (months / 12) + (days / 365);
	}

	// Field-table rule: which payout options are legal for a given tenure.
	function getAvailablePayoutFrequencies(totalDays) {
		if (totalDays < 30) {
			return ['MATURITY'];
		}
		if (totalDays < 90) {
			return ['MONTHLY', 'MATURITY'];
		}
		if (totalDays < 365) {
			return ['MONTHLY', 'QUARTERLY', 'MATURITY'];
		}
		return ['MONTHLY', 'QUARTERLY', 'ANNUALLY', 'MATURITY'];
	}

	function updatePayoutOptions() {
		var available = getAvailablePayoutFrequencies(getTenureDays());

		payoutRadios.forEach(function(radio) {
			var isAvailable = available.indexOf(radio.value) !== -1;

			radio.disabled = !isAvailable;

			if (radio.checked && !isAvailable) {
				radio.checked = false;
			}
		});

		// Fall back to On Maturity if the previously-selected option just
		// became unavailable (e.g. user shrank the tenure after picking Annually).
		var anyChecked = Array.prototype.some.call(payoutRadios, function(r) {
			return r.checked;
		});

		if (!anyChecked) {
			var maturityRadio = root.querySelector('input[value="MATURITY"]');

			if (maturityRadio) {
				maturityRadio.checked = true;
			}
		}
	}

	function fetchInterestRate() {
		var customerType = root.querySelector('input[name="customerType"]:checked').value;
		var productCode = productSelect.value;
		var tenureDays = getTenureDays();

		if (!productCode || tenureDays <= 0) {
			currentRate = null;
			setOutput('interestRate', '-');
			return Promise.resolve(null);
		}

		var url = restBase + '/interest-rates?customerType=' +
			encodeURIComponent(customerType) + '&productCode=' +
			encodeURIComponent(productCode) + '&tenureDays=' + tenureDays;

		return fetch(url, {
			headers: {Accept: 'application/json'},
			credentials: 'same-origin'
		})
			.then(function(res) {
				if (!res.ok) {
					throw new Error('Rate lookup failed: ' + res.status);
				}
				return res.json();
			})
			.then(function(rate) {
				currentRate = rate;
				setOutput('interestRate', rate.interestRatePct.toFixed(2) + '%');
				return rate;
			})
			.catch(function(err) {
				currentRate = null;
				setOutput('interestRate', '-');
				showError('Could not fetch the interest rate. Please try again.');
				/* eslint-disable-next-line no-console */
				console.error(err);
			});
	}

	function setOutput(field, value) {
		var el = root.querySelector('[data-output="' + field + '"]');

		if (el) {
			el.textContent = value;
		}
	}

	function showError(message) {
		if (!errorEl) {
			return;
		}
		errorEl.textContent = message;
		errorEl.hidden = !message;
	}

	function formatCurrency(amount) {
		return '₹' + amount.toFixed(2);
	}

	// Annexure 4: A = P x (1 + r/n)^(n x t), n fixed at 4 (quarterly).
	function calculateMaturity(principal, ratePct, tenureYears) {
		var n = 4;
		var r = ratePct / 100;

		return principal * Math.pow(1 + r / n, n * tenureYears);
	}

	// True year-by-year compounding for the Annually payout option: each full
	// year, the principal compounds quarterly (n=4) same as the cumulative
	// case, but the year's interest is paid out rather than reinvested, so
	// the next year starts from the same original principal again. This is
	// what the doc means by "annual payouts ... but compounding within the
	// year is still quarterly" — it is *not* totalInterest / tenureYears,
	// which would understate early payouts and overstate later ones once
	// compounding is taken into account.
	function calculateAnnualPayoutPerYear(principal, ratePct) {
		var n = 4;
		var r = ratePct / 100;

		return principal * (Math.pow(1 + r / n, n) - 1);
	}

	// Interest on the partial final year/period is not yet payable on an
	// annual schedule, so it's rolled into the payout at maturity rather
	// than averaged into the recurring per-year figure.
	function calculateAnnualRemainderAtMaturity(principal, ratePct, tenureYears) {
		var n = 4;
		var r = ratePct / 100;
		var remainderYears = tenureYears - Math.floor(tenureYears);

		if (remainderYears <= 0) {
			return 0;
		}

		return principal * (Math.pow(1 + r / n, n * remainderYears) - 1);
	}

	function calculatePayoutAmount(payoutFrequency, principal, ratePct, tenureYears, totalInterest) {
		var totalMonths = tenureYears * 12;

		switch (payoutFrequency) {
			case 'QUARTERLY':
				// flat non-cumulative quarterly interest, per Annexure 4 example
				// (100000 @ 8% => 100000*0.08/4 = 2000/quarter)
				return principal * (ratePct / 100) / 4;

			case 'MONTHLY':
				// total compounded interest spread evenly across the tenure,
				// per Annexure 4 example (8243 / 12 months ~= 687/month)
				return totalMonths > 0 ? totalInterest / totalMonths : 0;

			case 'ANNUALLY':
				// recurring amount paid at the end of each full year; any
				// partial trailing year is settled at maturity (see
				// calculateAnnualRemainderAtMaturity), not blended in here.
				return calculateAnnualPayoutPerYear(principal, ratePct);

			case 'MATURITY':
			default:
				return totalInterest;
		}
	}

	function validate(principal, tenureDays) {
		if (!principal || principal < 10000 || principal > 999999) {
			return 'Amount must be between ₹10,000 and ₹9,99,999.';
		}
		if (tenureDays <= 0) {
			return 'Please enter a valid tenure.';
		}
		if (!currentRate) {
			return 'Interest rate not available for this selection yet.';
		}
		return null;
	}

	function handleCalculate() {
		showError('');

		var principal = Number(root.querySelector('[data-field="amount"]').value);
		var tenureDays = getTenureDays();
		var tenureYears = getTenureYearsDecimal();
		var payoutFrequency = root.querySelector('input[name="payoutFrequency"]:checked').value;

		var validationError = validate(principal, tenureDays);

		if (validationError) {
			showError(validationError);
			return;
		}

		var maturityAmount = calculateMaturity(principal, currentRate.interestRatePct, tenureYears);
		var totalInterest = maturityAmount - principal;
		var payoutAmount = calculatePayoutAmount(
			payoutFrequency, principal, currentRate.interestRatePct, tenureYears, totalInterest);

		setOutput('maturityAmount', formatCurrency(maturityAmount));
		setOutput('interestAmount', formatCurrency(totalInterest));

		if (payoutFrequency === 'ANNUALLY') {
			var remainder = calculateAnnualRemainderAtMaturity(
				principal, currentRate.interestRatePct, tenureYears);

			setOutput('payoutAmount', formatCurrency(payoutAmount) + '/year' +
				(remainder > 0 ? ' (+ ' + formatCurrency(remainder) + ' at maturity for the part-year)' : ''));
		}
		else {
			setOutput('payoutAmount', formatCurrency(payoutAmount));
		}
	}

	// -- wiring --
	fetchProducts();
	updatePayoutOptions();

	['tenureYears', 'tenureMonths', 'tenureDays'].forEach(function(field) {
		root.querySelector('[data-field="' + field + '"]').addEventListener('input', function() {
			updatePayoutOptions();
			fetchInterestRate();
		});
	});

	root.querySelectorAll('input[name="customerType"]').forEach(function(radio) {
		radio.addEventListener('change', fetchInterestRate);
	});

	productSelect.addEventListener('change', fetchInterestRate);

	calculateBtn.addEventListener('click', handleCalculate);
})(fragmentElement.querySelector('.deposit-calculator'), configuration);

