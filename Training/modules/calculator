<#-- Fragment HTML executes as a FreeMarker template in Liferay, so this
     server-side block runs once per render, before any of the markup below
     reaches the browser. -->
<#assign interestRateUploadLocalService = serviceLocator.findService("com.sbi.core.service.service.InterestRateUploadLocalService")>
<#assign countryCode = (configuration.country)!"IN">
<#assign customerCategories = ["NORMAL", "SENIOR_CITIZEN", "CORPORATE"]>

<div class="deposit-calculator" data-fragment-namespace="fragment_10001">

	<#-- SSR-embedded rate data: application/json so it's inert until the
	     fragment's own JS explicitly JSON.parses it — never executed as a
	     script, unlike a bare `var DEPOSIT_RATES = [...]` global.

	     Single pass, not accumulate-into-a-list-then-reloop: the earlier
	     two-phase version (build `allRates` via `<#assign allRates =
	     allRates + [rate]>` inside a nested loop, then `<#list allRates as
	     rate>` separately) is what produced "rate has evaluated to null or
	     missing" here — whether from FreeMarker's own list-reassignment
	     semantics or a null element coming back from the persistence
	     finder, avoiding the two-phase pattern and guarding each element
	     with `rate??` sidesteps it either way. `!""`/`!0` defaults on the
	     individual fields are the same null-safety FreeMarker's error
	     message itself suggests. -->
	<script type="application/json" data-output="ratesData">
[
<#assign isFirstRate = true>
<#list customerCategories as category>
	<#assign categoryRates = (interestRateUploadLocalService.findByIsActiveStatusCountryNCategory(true, "ACTIVE", countryCode, category))![]>
	<#list categoryRates as rate>
		<#if rate??>
			<#if !isFirstRate>,</#if>
			<#assign isFirstRate = false>
			{
				"category": "${(rate.category!"")?js_string}",
				"interestType": "${(rate.interestType!"")?js_string}",
				"interestRate": ${(rate.interestRate!0)?c},
				"status": "${(rate.status!"")?js_string}"
			}
		</#if>
	</#list>
</#list>
]
	</script>

	<h2 class="dc-title">Deposit Calculator</h2>

	<div class="dc-row">
		<label class="dc-label">Type of Customer *</label>
		<div class="dc-radio-group" data-field="customerType">
		<#list customerCategories as category>
			<label>
				<input type="radio" name="customerType" value="${category?html}"<#if category_index == 0> checked</#if>>
				${category?replace("_", " ")?capitalize}
			</label>
		</#list>
		</div>
	</div>

	<div class="dc-row">
		<label class="dc-label" for="dc-interest-type">Please select the product *</label>
		<select id="dc-interest-type" class="dc-input" data-field="interestType"></select>
	</div>

	<div class="dc-row">
		<label class="dc-label">Tenure *</label>
		<div class="dc-tenure-group">
			<input type="number" class="dc-input" data-field="tenureYears" min="0" max="10" value="0" placeholder="Years">
			<input type="number" class="dc-input" data-field="tenureMonths" min="0" max="12" value="0" placeholder="Months">
			<input type="number" class="dc-input" data-field="tenureDays" min="0" max="31" value="0" placeholder="Days">
		</div>
	</div>

	<div class="dc-row">
		<label class="dc-label" for="dc-amount">How much amount do you want to invest? *</label>
		<input id="dc-amount" type="number" class="dc-input" data-field="amount"
			min="10000" max="999999" placeholder="Min 10,000 / Max 9,99,999">
	</div>

	<div class="dc-row">
		<label class="dc-label">When would you like to receive the interest? *</label>
		<div class="dc-radio-group" data-field="payoutFrequency">
			<label><input type="radio" name="payoutFrequency" value="MONTHLY" disabled> Monthly</label>
			<label><input type="radio" name="payoutFrequency" value="QUARTERLY" disabled> Quarterly</label>
			<label><input type="radio" name="payoutFrequency" value="ANNUALLY" disabled> Annually</label>
			<label><input type="radio" name="payoutFrequency" value="MATURITY" checked> On Maturity</label>
		</div>
	</div>

	<p class="dc-error" data-field="error" hidden></p>

	<button type="button" class="dc-calculate-btn" data-action="calculate">Calculate</button>

	<div class="dc-results">
		<h3>Maturity &amp; Details</h3>
		<div class="dc-card">
			<span class="dc-card-label">Maturity Amount (Principal + Interest)</span>
			<span class="dc-card-value" data-output="maturityAmount">-</span>
		</div>
		<div class="dc-card">
			<span class="dc-card-label">Total Interest Amount (Accumulated)</span>
			<span class="dc-card-value" data-output="interestAmount">-</span>
		</div>
		<div class="dc-card">
			<span class="dc-card-label">Interest Rate</span>
			<span class="dc-card-value" data-output="interestRate">-</span>
		</div>
		<div class="dc-card">
			<span class="dc-card-label">Interest Payout Amount (Monthly / Quarterly / Annually / On Maturity)</span>
			<span class="dc-card-value" data-output="payoutAmount">-</span>
		</div>
	</div>

	<div class="dc-row">
		<button type="button" class="dc-secondary-btn" data-action="view-rates">View current interest rates</button>
	</div>

	<table class="dc-rates-table" data-output="ratesTable" hidden>
		<thead>
			<tr>
				<th>Category</th>
				<th>Interest Type</th>
				<th>Rate</th>
				<th>Status</th>
			</tr>
		</thead>
		<tbody data-output="ratesTableBody"></tbody>
	</table>

	<p class="dc-disclaimer">*Maturity amount shown here is indicative only. Rates reflect the page's last render.</p>
</div>



