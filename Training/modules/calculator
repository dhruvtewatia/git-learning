--- InterestRateResourceImpl.java (hand-written, implements generated base) --
package com.lr.trainong.depositrate.rest.internal.resource.v1_0;

@Component(properties = "OSGI-INF/liferay/rest/v1_0/interest-rate.properties",
	service = InterestRateResource.class)
public class InterestRateResourceImpl extends BaseInterestRateResourceImpl {

	@Override
	public InterestRate getInterestRate(
			String customerType, String productCode, int tenureDays)
		throws Exception {

		com.lr.trainong.depositrate.model.InterestRate rate =
			_interestRateLocalService.findByCustomerType_Product_Tenure(
				customerType, productCode, tenureDays);

		if (rate == null) {
			throw new NoSuchInterestRateException(
				"No rate for " + customerType + "/" + productCode +
					"/" + tenureDays + "d");
		}

		return new InterestRate() {
			{
				setCustomerType(rate.getCustomerType());
				setProductCode(rate.getProductCode());
				setInterestRatePct(rate.getInterestRatePct());
				setCompoundingFrequency(rate.getCompoundingFrequency());
				setTenureMinDays(rate.getTenureMinDays());
				setTenureMaxDays(rate.getTenureMaxDays());
			}
		};
	}

	@Reference
	private InterestRateLocalService _interestRateLocalService;
}

--- ProductResourceImpl.java (hand-written, implements generated base) -------
package com.lr.trainong.depositrate.rest.internal.resource.v1_0;

@Component(properties = "OSGI-INF/liferay/rest/v1_0/product.properties",
	service = ProductResource.class)
public class ProductResourceImpl extends BaseProductResourceImpl {

	@Override
	public Page<Product> getProductsPage() throws Exception {
		List<com.lr.trainong.depositrate.model.DepositProduct> products =
			_depositProductLocalService.findByActive(true);

		return Page.of(
			ListUtil.toList(
				products,
				product -> {
					Product dto = new Product();

					dto.setProductCode(product.getProductCode());
					dto.setProductName(product.getProductName());

					return dto;
				}));
	}

	@Reference
	private DepositProductLocalService _depositProductLocalService;
}

-- Product list changes about as rarely as the rate card itself, so the same
-- PortalCache approach from the note below applies here too — cache the
-- getProductsPage() result and invalidate it from wherever products are
-- edited (admin UI / data import), rather than re-querying on every fragment
-- render.

-- Rates change rarely (a rate-card update, not a live feed) -- so cache the
-- lookup instead of hitting the DB on every calculator interaction:
--
--   @Reference
--   private volatile MultiVMPool _multiVMPool;   // or PortalCache directly
--
--   PortalCache<String, InterestRate> cache = _multiVMPool.getCache(
--       "DEPOSIT_RATE_CACHE");
--   String key = customerType + "|" + productCode + "|" + tenureDays;
--   InterestRate cached = cache.get(key);
--   if (cached == null) { cached = lookup(...); cache.put(key, cached); }
--
-- This turns a DB round-trip into a memory lookup for the 99% case where the
-- rate card hasn't changed since the last portal restart, without you having
-- to hand-roll invalidation — PortalCache is already cluster-aware.

